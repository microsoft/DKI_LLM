# ============================================================
# Deep Research Baselines — Environment Variables
# Copy this file to .env and fill in your credentials:
#   cp .env.template .env
# ============================================================

# ======================== LLM Config ========================
# Provider: "azure_openai", "openai", or "custom"
# Uncomment ONE of the three sections below.

# --- Option 1: Azure OpenAI ---
LLM_PROVIDER=azure_openai
LLM_MODEL_NAME=gpt-4.1-20250414
LLM_BASE_URL=https://your-endpoint.openai.azure.com
LLM_API_KEY=
LLM_API_VERSION=2025-04-01-preview
LLM_TEMPERATURE=0.0
# Azure AD auth (set to true to use AAD instead of API key)
AZURE_OPENAI_USE_AAD=false
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# --- Option 2: OpenAI ---
# LLM_PROVIDER=openai
# LLM_MODEL_NAME=gpt-4.1
# LLM_API_KEY=sk-proj-xxx
# LLM_TEMPERATURE=0.0

# --- Option 3: Custom (any OpenAI-compatible endpoint) ---
# LLM_PROVIDER=custom
# LLM_MODEL_NAME=your-model-name
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=https://your-provider.com/v1
# LLM_TEMPERATURE=0.0
# LLM_API_VERSION=              # optional, sent as ?api-version= query param
# LLM_EXTRA_HEADERS='{}'        # optional, JSON dict of extra HTTP headers

# ====================== Search Config ======================
# Search backend is selected via CLI --search-provider (bing|serper).
# Configure the credentials for the backend(s) you use.

# Bing Search
BING_APP_ID=
BING_ENDPOINT=https://www.bingapis.com/api/v7/search

# Serper (Google via serper.dev)
# SERPER_KEY_ID=

# ==================== Page Reading Config ====================
# Method: "crawl4ai", "jina", or "firecrawl"
READPAGE_METHOD=crawl4ai

# Crawl4AI
# CRAWL4AI_URL=http://localhost:3002

# Jina
# READER_URL=https://r.jina.ai/
# JINA_API_KEYS=key1,key2

# Firecrawl
# FIRECRAWL_API_URL=http://localhost:3002
# FIRECRAWL_API_KEY=

# Use Jina as fallback when primary reader fails
JINA_FALLBACK=false

# =================== Knowledge Graph Config ===================
# Semantic clustering (HDBSCAN)
DEEPRESEARCH_ENABLE_SEMANTIC_CLUSTERING=false
DEEPRESEARCH_HDBSCAN_MIN_CLUSTER_SIZE=3
DEEPRESEARCH_SEMANTIC_CLUSTER_MERGE=false

# Community detection (Leiden)
DEEPRESEARCH_COMMUNITY_DETECTION_ENABLED=true
DEEPRESEARCH_COMMUNITY_DETECTION_METHOD=leiden
DEEPRESEARCH_LEIDEN_RESOLUTION=0.5
DEEPRESEARCH_LEIDEN_ITERATIONS=3

# =================== Neo4j (Optional) ===================
NEO4J_KG_ENABLED=false
NEO4J_GDS_LEIDEN_ENABLED=false
# NEO4J_BOLT_URL=bolt://neo4j:password@localhost:7687
# NEO4J_URI=neo4j+s://xxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# ======================= Language =======================
LANGUAGE=English
# LANGUAGE=Chinese
